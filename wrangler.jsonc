{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "citation-reader",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public",
    // client disconnectをRequest.signal.abortイベントで受け取るために必須。
    // 未設定だとanthropicStream.abort() が発火せず、
    // キャンセル後もAnthropic API課金が継続する。
    "enable_request_signal",
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "citation-reader",
    },
  ],
  // Cloudflare Workers Rate Limiting binding。
  // namespace_idはCloudflareアカウント内で一意になるよう定義する正の整数文字列。
  // 同じnamespace_idを別Workerでも使うと、同一keyのrate limit counterを共有する。
  // dev / Vitest環境ではbindingがundefinedなのでsrc/lib/rate-limit-binding.ts
  // が自動でin-memory fallbackする設計。
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 10,
        "period": 60,
      },
    },
  ],
}
