# Next.js (next dev) 用ローカル環境変数テンプレート
#
# 使い方:
#   1. このファイルを.env.localとしてコピー
#   2. 実際の値を設定（.env.localは.gitignoreで除外されます）
#
# 本ファイル自体はcommit可能（ダミー値しか書かない）

# PasswordGateで入力するアクセスキー（任意に決める、8文字以上推奨）
ACCESS_PASSWORD=change-me-to-your-own-password

# Anthropic APIキー（https://console.anthropic.com/settings/keys で発行）
# 注意: 必ずSpend Limitを設定してから使用すること（$5〜$10/月推奨）
ANTHROPIC_API_KEY=<your-anthropic-api-key>
